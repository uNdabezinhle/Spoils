# Django
DJANGO_SECRET_KEY=change-me-to-a-secure-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# Database (local without Docker)
DATABASE_URL=postgres://spoil:spoil@localhost:5432/spoil

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# CORS (Flutter dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Paystack (test mode)
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (console backend used when SMTP not set)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=hello@spoil.co.za

# Firebase (FCM push notifications)
FIREBASE_CREDENTIALS_PATH=