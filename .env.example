# Django
DJANGO_SECRET_KEY=change-me-to-a-secure-random-string
DJANGO_DEBUG=true
# Add your LAN IP for physical devices, e.g. 192.168.1.42
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2
DJANGO_USE_RUNSERVER=true

# Database (local without Docker)
DATABASE_URL=postgres://spoil:spoil@localhost:5432/spoil

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# CORS (Flutter dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080
# Set to true in production when DEBUG=false and origins are locked down
CORS_ALLOW_ALL=false

# Paystack — leave empty for demo checkout (no real charge)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (console backend used when SMTP not set)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=hello@spoil.co.za

# Firebase (FCM push notifications)
FIREBASE_CREDENTIALS_PATH=
# Social login (optional)
GOOGLE_OAUTH_CLIENT_ID=
APPLE_CLIENT_ID=

# Flutter (optional dart-defines when running mobile):
#   API_BASE_URL=http://localhost:8000/api/v1
#   FIREBASE_PROJECT_ID=... FIREBASE_API_KEY=... FIREBASE_APP_ID=...
#   FIREBASE_MESSAGING_SENDER_ID=... FIREBASE_AUTH_DOMAIN=... FIREBASE_STORAGE_BUCKET=...
#   GOOGLE_CLIENT_ID=...  (must match GOOGLE_OAUTH_CLIENT_ID)
#
# Subscriptions use the same Paystack keys as checkout. Leave empty for demo billing.
# Celery beat runs subscription renewals, auto-gift proposals, and reminder emails (needs REDIS_URL).
#
# Production: copy .env.production.example → .env on your server, then:
#   docker compose -f docker-compose.prod.yml up -d --build
#   docker compose -f docker-compose.prod.yml exec api python manage.py production_check --strict