# Django
DJANGO_SECRET_KEY=change-me-to-a-secure-random-string
DJANGO_DEBUG=true
# Add your LAN IP for physical devices, e.g. 192.168.1.42
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2
DJANGO_USE_RUNSERVER=true

# Database (local without Docker)
DATABASE_URL=postgres://spoil:spoil@localhost:5432/spoil

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# CORS (Flutter dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080
# Set to true in production when DEBUG=false and origins are locked down
CORS_ALLOW_ALL=false

# Paystack — leave empty for demo checkout (no real charge)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (console backend used when SMTP not set)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=hello@spoil.co.za

# Firebase (FCM push notifications)
FIREBASE_CREDENTIALS_PATH=
# Social login (optional)
GOOGLE_OAUTH_CLIENT_ID=
APPLE_CLIENT_ID=

# Flutter (optional): pass when running with push enabled
# --dart-define=FIREBASE_PROJECT_ID=... --dart-define=FIREBASE_API_KEY=...
# --dart-define=FIREBASE_APP_ID=... --dart-define=FIREBASE_MESSAGING_SENDER_ID=...
# --dart-define=GOOGLE_CLIENT_ID=...  (must match GOOGLE_OAUTH_CLIENT_ID)