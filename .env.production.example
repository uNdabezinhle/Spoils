# Spoils production environment — copy to .env on your server and fill every value.
# Never commit the real .env file.

# --- Django core (required) ---
DJANGO_SECRET_KEY=generate-a-50-char-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.spoils.co.za,spoil-api.yourhost.com
DJANGO_USE_RUNSERVER=false
DJANGO_BEHIND_PROXY=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_HSTS_SECONDS=31536000
DJANGO_HSTS_PRELOAD=false
# HTTPS origins that POST to Django admin or session-auth endpoints
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.spoils.co.za

# --- Database (required) ---
POSTGRES_DB=spoil
POSTGRES_USER=spoil
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgres://spoil:change-me-strong-db-password@db:5432/spoil

# --- Redis / Celery (required for reminders, renewals, surprise mode) ---
REDIS_URL=redis://redis:6379/0

# --- CORS — lock down in production ---
CORS_ALLOWED_ORIGINS=https://app.spoils.co.za
CORS_ALLOW_ALL=false

# --- Paystack live or test keys (required for real payments) ---
# Dashboard: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxx
# Webhook URL to register in Paystack: https://api.spoils.co.za/api/v1/orders/paystack/webhook/

# --- Cloudinary (recommended for photo uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email / SMTP (required for reminder emails & order confirmations) ---
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=hello@spoil.co.za
EMAIL_USE_TLS=true

# --- Firebase Admin SDK (required for push notifications) ---
# Download JSON from Firebase Console → Project settings → Service accounts
# Mount into container, e.g. /run/secrets/firebase-adminsdk.json
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase-adminsdk.json

# --- Social login (optional) ---
GOOGLE_OAUTH_CLIENT_ID=123456789.apps.googleusercontent.com
APPLE_CLIENT_ID=com.spoils.app

# --- Flutter production build (dart-define at CI/build time) ---
# API_BASE_URL=https://api.spoils.co.za/api/v1
# FIREBASE_PROJECT_ID=...
# FIREBASE_API_KEY=...
# FIREBASE_APP_ID=...
# FIREBASE_MESSAGING_SENDER_ID=...
# GOOGLE_CLIENT_ID=...  (same as GOOGLE_OAUTH_CLIENT_ID)